# =============================================================================
# db_user_exists - Check if db_user actually exists in MySQL/MariaDB
# =============================================================================
#
# GENERAL PURPOSE:
# Checks whether the given username exists in the database (mysql.user table).
# This is a pure existence check — it does NOT test password correctness.
#
# YOUR ORIGINAL REQUIREMENT (recorded here for safety - DO NOT VIOLATE):
# "The setup database should try to check what is the current db_user and 
# db_password stored in application-druid.yml BEFORE backup.
# Within the same procedures, it should check if the db_user exists, 
# if the db_password correct.
# If they are correct, no need to create a new db_user and corresponding db_password."
#
# CRITICAL RULE FROM YOU:
# We must know whether the user exists **before** deciding to create or reuse.
# Never silently recreate or change password of an existing user.
#
# ────────────────────────────────────────────────
# CIAO PRINCIPLES APPLIED
# ────────────────────────────────────────────────
# Principle 1 (Caution)      - Safe query, no side effects, proper error handling
# Principle 2 (Intentional)  - Clear purpose, your requirement documented
# Principle 3 (Anti-fragile) - Works with both mysql and mariadb, survives missing privileges
# Principle 7 (Reusable)     - Can be used in other database-related scripts
# Principle 10 (Backup)      - Pure read-only check (no modification)
#
# CRITICAL DEFENSIVE RULES:
# - This function ONLY checks existence, does NOT test password.
# - Uses direct query on mysql.user table (most reliable method).
# - Works whether run as root or normal user (via sudo mysql when needed).
# - Returns 0 = user exists, 1 = user does not exist or error.
# - Never modifies database.
#
# !!! DO NOT MODIFY OR SIMPLIFY THIS FUNCTION !!!
# This is the dedicated existence checker as requested.
# Any change must preserve the read-only nature and your documented requirement.
#
# Last reviewed: 29 April 2026
# =============================================================================

db_user_exists() {
    local user="$1"

    [ -z "$user" ] && return 1

    local mysql_cmd="mysql"
    if command -v mariadb >/dev/null 2>&1; then
        mysql_cmd="mariadb"
    fi

    # Check existence in mysql.user table
    if echo "SELECT 1 FROM mysql.user WHERE user='${user}' AND host='localhost' LIMIT 1" | \
       sudo $mysql_cmd -s 2>/dev/null | grep -q "^1"; then
        return 0   # User exists
    fi

    # Fallback without sudo (if running as root)
    if echo "SELECT 1 FROM mysql.user WHERE user='${user}' AND host='localhost' LIMIT 1" | \
       $mysql_cmd -s 2>/dev/null | grep -q "^1"; then
        return 0
    fi

    return 1   # User does not exist or query failed
}

