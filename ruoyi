# All user-facing text (out_info, out_success, out_warn, out_error, etc.) MUST go through this
# function to maintain consistency and JSON-mode compatibility.
#
# INTENTIONAL DESIGN:
# This is the single source of truth for all terminal output in the project.
# Never use raw echo/printf for user messages elsewhere.
#
# Last reviewed: 29 April 2026
# =============================================================================
out_text() {
    local level="$1" msg="$2"
    : "${JSON:=0}" : "${QUIET:=0}"
    [ "${JSON}" -eq 1 ] && return 0
    [ "${QUIET}" -eq 1 ] && [ "${level}" != "out_error" ] && return 0

    local RED='' GREEN='' YELLOW='' BLUE='' NC=''
    [ "${TTY:-0}" -eq 1 ] && [ "${QUIET}" -eq 0 ] && [ "${JSON}" -eq 0 ] && {
        RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; BLUE='\033[0;34m'; NC='\033[0m'
    }

    case "${level}" in
        out_error) printf >&2 "${RED}[ERROR]${NC} %s\n" "${msg}" ;; out_warn) printf >&2 "${YELLOW}[WARN]${NC} %s\n" "${msg}" ;;
        out_info) printf "${GREEN}[INFO]${NC} %s\n" "${msg}" ;; out_success) printf "${GREEN}[OK]${NC} %s\n" "${msg}" ;;
        plain) printf "%s\n" "${msg}" ;; plain_n) printf "%s" "${msg}" ;;
        *) printf "%s\n" "${msg}" ;;
    esac
}

