# =============================================================================
# db_check_credentials - Check existing credentials and decide action
# =============================================================================
#
# YOUR ORIGINAL REQUIREMENT (recorded here for safety - DO NOT VIOLATE):
# "The setup database should try to check what is the current db_user and 
# db_password stored in application-druid.yml BEFORE backup.
# Within the same procedures, it should check if the db_user exists, 
# if the db_password correct.
# If they are correct, no need to create a new db_user and corresponding db_password."
#
# Returns:
#   use_existing=1   → reuse existing user (no backup/create/update)
#   use_existing=0   → need to create new user
#
# CIAO-Lite Protection Zone - Do NOT simplify or remove this logic
# Last reviewed: 29 April 2026
# =============================================================================

db_check_credentials() {
    local config_path="$1"

    local lines
    lines=$(db_extract_config_yml "$config_path" 2>/dev/null)

    local dbname=$(echo "$lines" | sed -n '1p')
    local user=$(echo "$lines" | sed -n '2p')
    local pass=$(echo "$lines" | sed -n '3p')

    local use_existing=0

    if [ -n "$user" ] && [ ${#pass} -gt 3 ]; then
        if db_user_exists "$user"; then
            out_info "Valid existing user '${user}' found in DB" >&2
            final_db_user="${user}"
            final_db_pass="${pass}"
            use_existing=1
        else
            out_info "User '${user}' from yml does NOT exist → will create new" >&2
            final_db_user="${user}"
            final_db_pass="${pass:-$(util_generate_db_pass)}"
            use_existing=0
        fi
    else
        out_warn "No valid credentials in yml → creating new ruoyi_user" >&2
        final_db_user="${DB_USER}"
        final_db_pass="$(util_generate_db_pass)"
        use_existing=0
    fi

    printf '%s\n%s\n%s\n%s\n' "$use_existing" "${dbname}" "${final_db_user}" "${final_db_pass}"
}

# =============================================================================
# db_create_new_user - Create new database user only if it does not exist
# =============================================================================
#
# YOUR STRICT REQUIREMENT (recorded here for safety - DO NOT VIOLATE):
# Receive db_user and db_passwd.
# 1. Use sudo to check if db_user exists.
# 2. Explicitly say "User XXX exists" or "User XXX does not exist".
# 3. Only create user if it does NOT exist.
#
# CIAO-Lite Protection Zone - Follow exactly. No extra logic.
# Last reviewed: 29 April 2026
# =============================================================================

db_create_new_user() {
    local db_user="$1"
    local db_pass="$2"
    local db_name="${3:-${DB_NAME}}"

    [ -z "$db_user" ] && {
        out_error "db_create_new_user: db_user is empty" >&2
        return 1
    }

    out_info "Checking if user '${db_user}' exists in database..." >&2
    if sudo mysql -s -e "SELECT 1 FROM mysql.user WHERE user='${db_user}' AND host='localhost' LIMIT 1" 2>/dev/null | grep -q "^1"; then
        out_warn "User '${db_user}' already EXISTS in database" >&2
        out_warn "→ Will NOT create duplicate user or change password." >&2
        printf '%s' "$db_pass"
        return 0
    fi

    out_info "User '${db_user}' does NOT exist → creating..." >&2
    sudo mysql -e "CREATE DATABASE IF NOT EXISTS \`${db_name}\` CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;" || out_die "Failed to create database"
    sudo mysql -e "CREATE USER IF NOT EXISTS '${db_user}'@'localhost' IDENTIFIED BY '${db_pass}';" || out_die "Failed to create user"
    sudo mysql -e "GRANT ALL PRIVILEGES ON \`${db_name}\`.* TO '${db_user}'@'localhost';" || out_die "Failed to grant privileges"
    sudo mysql -e "FLUSH PRIVILEGES;"

    out_success "User '${db_user}' created successfully" >&2
    printf '%s' "$db_pass"
}

