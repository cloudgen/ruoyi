# 3. Respect --force / FORCE_REINSTALL — do not delete user data silently.
# 4. All user-visible messages MUST go through info()/success()/warn()/die() only.
# 5. Git clone uses --depth 1 for speed and minimal footprint.
# 6. sed operations are defensive (2>/dev/null || true) but still backed up first.
#
# NON-INTERACTIVE MODE REMINDER:
# In non-interactive mode (curl | bash, --quiet, no TTY, CI), this function
# still performs safely using FORCE_REINSTALL as the only trigger for destructive
# actions. No interactive prompts are used here (prompt_yes_no is handled higher up).
#
# SDKMAN NOTE (Intentional Separation):
# SDKMAN is used only for Java 21 + Maven (setup_sdkman/setup_java/setup_maven).
# This function handles pure project cloning and configuration — native git/sed only.
# This separation follows Least-Privilege and Anti-fragility (Principles 8 & 3).
#
# !!! DO NOT MODIFY OR SIMPLIFY THIS FUNCTION !!!
# This function is battle-tested for fresh clones vs existing projects.
# Simplifying it (e.g. unconditional rm -rf) has caused user data loss in the past.
# Any change must preserve backup strategy, FORCE_REINSTALL logic, and output_text compliance.
#
# Designed to be reusable in other Spring Boot / RuoYi-style installers.
#
# Last reviewed & aligned with CIAO v2.9.1: 14 April 2026
# =============================================================================

clone_ruoyi() {
    # --- Safe Variable Defaults (repeated on purpose - CIAO Principle 1) ---

    : "${APP_NAME:=app}"
    : "${PROJECT_NAME:=${APP_NAME}-demo}"
    : "${PROJECT_DIR:=${HOME}/${PROJECT_NAME}}"
    : "${FORCE_REINSTALL:=0}"
    : "${RUOYI_GIT_REPO:=https://github.com/yangzongzhuan/RuoYi.git}"
    : "${JAVA_VERSION:=21}"
    : "${PORT:=8080}"
    : "${JSON:=0}"
    : "${QUIET:=0}"

    info "Cloning RuoYi project..."

    # Backup strategy before any destructive action (CIAO Principle 10)
    if [ -d "${PROJECT_DIR}" ]; then
        backup_ruoyi_config "${PROJECT_DIR}" "pre-clone" || warn "Backup failed — continuing with caution"
    fi

    if [ -d "${PROJECT_DIR}" ]; then
        if [ "${FORCE_REINSTALL:-0}" -eq 1 ]; then
            info "Force reinstall detected → removing old project folder after backup"
            # Final safety check before rm -rf
            if [ -z "${PROJECT_DIR}" ] || [ "${PROJECT_DIR}" = "/" ] || [ "${PROJECT_DIR}" = "${HOME}" ]; then
                die "Refusing to rm -rf dangerous path: ${PROJECT_DIR}"
            fi
            rm -rf "${PROJECT_DIR}" || die "Failed to remove old project directory"
        else
            info "Project already exists at ${PROJECT_DIR}. Skipping clone."
            info "Use --force to reset (data will be backed up first)."
            return 0
        fi
    fi

    # Perform clone
    git clone --depth 1 "${RUOYI_GIT_REPO}" "${PROJECT_DIR}" || die "Git clone failed"

    cd "${PROJECT_DIR}" || die "Cannot cd into ${PROJECT_DIR}"

    # Backup again before any file modifications (sed)
    backup_ruoyi_config "${PROJECT_DIR}/pom.xml" "pre-sed" || true
    backup_ruoyi_config "${PROJECT_DIR}/ruoyi-admin/src/main/resources/application.yml" "pre-sed" || true

    # Update Java version (defensive sed)
    sed -i "s|<java.version>.*</java.version>|<java.version>${JAVA_VERSION}</java.version>|g" pom.xml 2>/dev/null || true

    # Update port (defensive)
    local config_file="ruoyi-admin/src/main/resources/application.yml"
    if [ -f "$config_file" ]; then
        sed -i "s/port: 80/port: ${PORT}/g" "$config_file" 2>/dev/null || true
        info "Updated server port to ${PORT} in ${config_file}"
    else
        warn "application.yml not found — port update skipped"
    fi

    success "RuoYi project ready at ${PROJECT_DIR}"
    success "Use '${APP_NAME} mysql' or '${APP_NAME} mariadb' (default) for database setup next."
}

# =============================================================================
# backup_ruoyi_config() - Create dated backup before any modification
# =============================================================================
#
# GENERAL PURPOSE:
# Creates a dated backup of important RuoYi configuration files or directories
# before destructive or modifying operations (rm -rf, sed, DB config changes).
#
# This implements CIAO Principle 10 (Right Backup & Restore Strategy).
#
# ────────────────────────────────────────────────
# CIAO PRINCIPLES APPLIED (v2.9.1)
# ────────────────────────────────────────────────
# Principle 1  (Caution)               - Safe path validation
# Principle 2  (Intentional Verbosity) - Full header + comments
# Principle 3  (Anti-fragile)          - Survives missing files gracefully
# Principle 7  (Reusable)              - Designed for reuse in other projects
# Principle 9  (Safe Temporary Files)  - Uses mktemp where needed
# Principle 10 (Backup Strategy)       - Dated backup with counter
#
# CRITICAL DEFENSIVE RULES:
# - Never modify files without creating backup first.
# - Refuse dangerous paths (/, $HOME, empty).
# - Backup name format: <name>.YYYYMMDD-N.bak
# - All messages go through output_text helpers only.
#
# !!! DO NOT MODIFY OR SIMPLIFY THIS FUNCTION !!!
# This is the central backup mechanism. Any change must preserve dated backup
# naming and safety checks to prevent accidental data loss.
#
# Last reviewed & aligned with CIAO v2.9.1: 14 April 2026
# =============================================================================

backup_ruoyi_config() {
    # --- Safe Variable Defaults ---
    : "${APP_NAME:=app}"
    : "${PROJECT_NAME:=${APP_NAME}-demo}"
    : "${PROJECT_DIR:=${HOME}/${PROJECT_NAME}}"
    : "${JSON:=0}"
    : "${QUIET:=0}"

    local target="$1"
    local reason="${2:-pre-change}"

    if [ -z "$target" ]; then
        return 1
    fi

    # Safety check
    if [ "$target" = "/" ] || [ "$target" = "${HOME}" ] || [ -z "$target" ]; then
        warn "Refusing to backup dangerous path: $target"
        return 1
    fi

    local timestamp
    timestamp=$(date +%Y%m%d)
    local counter=1
    local backup_path

    if [ -d "$target" ]; then
        backup_path="${target}.${timestamp}-${counter}.bak"
        while [ -e "$backup_path" ]; do
            counter=$((counter + 1))
            backup_path="${target}.${timestamp}-${counter}.bak"
        done
        cp -a "$target" "$backup_path" 2>/dev/null && \
            info "Backup created: $backup_path (reason: $reason)" || \
            warn "Failed to create backup of directory $target"
    elif [ -f "$target" ]; then
        backup_path="${target}.${timestamp}-${counter}.bak"
        while [ -e "$backup_path" ]; do
            counter=$((counter + 1))
            backup_path="${target}.${timestamp}-${counter}.bak"
        done
        cp "$target" "$backup_path" 2>/dev/null && \
            info "Backup created: $backup_path (reason: $reason)" || \
            warn "Failed to create backup of file $target"
    fi
}

