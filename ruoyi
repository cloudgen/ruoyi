    : "${QUIET:=0}"

    info "Setting up MariaDB (default database engine for RuoYi)"

    # Backup before any modification
    backup_ruoyi_config "${PROJECT_DIR}/ruoyi-admin/src/main/resources/application-druid.yml" "pre-mariadb-setup"

    if [ ! -d "${PROJECT_DIR}" ]; then
        die "Project directory ${PROJECT_DIR} not found. Run 'ruoyi' first as normal user."
    fi

    cd "${PROJECT_DIR}" || die "Cannot cd into ${PROJECT_DIR}"

    # Internal sudo escalation for privileged operations only
    info "Installing MariaDB server (requires sudo)..."
    sudo apt-get update -y && \
    sudo apt-get install -y mariadb-server mariadb-client || die "MariaDB installation failed"

    sudo systemctl start mariadb 2>/dev/null || warn "Failed to start mariadb service"
    sudo systemctl enable mariadb 2>/dev/null || warn "Failed to enable mariadb on boot"

    local db_pass="${DB_PASSWORD:-$(generate_db_password)}"

    info "Creating database and user..."
    sudo mysql -e "CREATE DATABASE IF NOT EXISTS \`${DB_NAME}\` CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;" || die "Failed to create database"
    sudo mysql -e "CREATE USER IF NOT EXISTS '${DB_USER}'@'localhost' IDENTIFIED BY '${db_pass}';" || die "Failed to create user"
    sudo mysql -e "GRANT ALL PRIVILEGES ON \`${DB_NAME}\`.* TO '${DB_USER}'@'localhost';" || die "Failed to grant privileges"
    sudo mysql -e "FLUSH PRIVILEGES;"

    # Import schema
    local sql_file=$(ls sql/ry*.sql 2>/dev/null | sort -r | head -n 1)
    if [ -n "$sql_file" ]; then
        sudo mysql "${DB_NAME}" < "$sql_file" && info "Main schema imported" || warn "Schema import failed"
    fi

    if [ -f "sql/quartz.sql" ]; then
        sudo mysql "${DB_NAME}" < sql/quartz.sql && info "Quartz tables imported" || warn "Quartz import failed"
    fi

    # Update configuration
    local config_file="ruoyi-admin/src/main/resources/application-druid.yml"
    if [ -f "$config_file" ]; then
        sed -i "s|url: jdbc:mysql://localhost:3306/ry|url: jdbc:mysql://localhost:3306/${DB_NAME}|g" "$config_file" 2>/dev/null || true
        sed -i "s|username: root|username: ${DB_USER}|g" "$config_file" 2>/dev/null || true
        sed -i "s|password:.*|password: ${db_pass}|g" "$config_file" 2>/dev/null || true
        info "Updated database configuration"
    fi

    success "MariaDB setup completed successfully!"
    success "Database : ${DB_NAME}"
    success "User     : ${DB_USER}"
    success "Password : ${db_pass}   ← Please save this password!"
}

