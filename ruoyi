# =============================================================================
# util_backup() - Create dated backup before any modification
# =============================================================================
#
# GENERAL PURPOSE:
# Creates a dated backup of important RuoYi configuration files or directories
# before destructive or modifying operations (rm -rf, sed, DB config changes).
#
# This implements CIAO Principle 10 (Right Backup & Restore Strategy).
#
# ────────────────────────────────────────────────
# CIAO PRINCIPLES APPLIED (v2.9.1)
# ────────────────────────────────────────────────
# Principle 1  (Caution)               - Safe path validation
# Principle 2  (Intentional Verbosity) - Full header + comments
# Principle 3  (Anti-fragile)          - Survives missing files gracefully
# Principle 7  (Reusable)              - Designed for reuse in other projects
# Principle 9  (Safe Temporary Files)  - Uses mktemp where needed
# Principle 10 (Backup Strategy)       - Dated backup with counter
#
# CRITICAL DEFENSIVE RULES:
# - Never modify files without creating backup first.
# - Refuse dangerous paths (/, $HOME, empty).
# - Backup name format: <name>.YYYYMMDD-N.bak
# - All messages go through out_text helpers only.
#
# !!! DO NOT MODIFY OR SIMPLIFY THIS FUNCTION !!!
# This is the central backup mechanism. Any change must preserve dated backup
# naming and safety checks to prevent accidental data loss.
#
# Last reviewed: 29 April 2026
# =============================================================================

util_backup() {
    # --- Safe Variable Defaults ---
    : "${APP_NAME:=app}"
    : "${PROJECT_NAME:=${APP_NAME}-demo}"
    : "${PROJECT_DIR:=${HOME}/${PROJECT_NAME}}"
    : "${JSON:=0}"
    : "${QUIET:=0}"

    local target="$1"
    local reason="${2:-pre-change}"

    if [ -z "$target" ]; then
        return 1
    fi

    # Safety check
    if [ "$target" = "/" ] || [ "$target" = "${HOME}" ] || [ -z "$target" ]; then
        out_warn "Refusing to backup dangerous path: $target"
        return 1
    fi

    local timestamp
    timestamp=$(date +%Y%m%d)
    local counter=1
    local backup_path

    if [ -d "$target" ]; then
        backup_path="${target}.${timestamp}-${counter}.bak"
        while [ -e "$backup_path" ]; do
            counter=$((counter + 1))
            backup_path="${target}.${timestamp}-${counter}.bak"
        done
        cp -a "$target" "$backup_path" 2>/dev/null && \
            out_info "Backup created: $backup_path (reason: $reason)" || \
            out_warn "Failed to create backup of directory $target"
    elif [ -f "$target" ]; then
        backup_path="${target}.${timestamp}-${counter}.bak"
        while [ -e "$backup_path" ]; do
            counter=$((counter + 1))
            backup_path="${target}.${timestamp}-${counter}.bak"
        done
        cp "$target" "$backup_path" 2>/dev/null && \
            out_info "Backup created: $backup_path (reason: $reason)" || \
            out_warn "Failed to create backup of file $target"
    fi
}

# =============================================================================
# ruo_build_run() - Build and launch the RuoYi Spring Boot application
# =============================================================================
#
# GENERAL PURPOSE:
# Builds the RuoYi project using Maven (skipping tests), verifies the JAR exists,
# then launches ruoyi-admin.jar with the configured Java from SDKMAN.
#
# ────────────────────────────────────────────────
# STEPS (in order)
# ────────────────────────────────────────────────
# 1. Safe variable defaults (PROJECT_DIR, PORT, etc.)
# 2. Change to project directory with safety check
# 3. Run Maven clean package -Dmaven.test.skip=true
# 4. Verify the expected JAR file was produced
# 5. In JSON mode: output structured out_success out_info
# 6. In human mode: display clear startup banner with URL and credentials
# 7. exec java -jar to replace current process cleanly
#
# LESSON LEARNED:
# Previous versions used raw echo/printf and unquoted variables, breaking
# single source of truth and introducing subtle bugs in non-interactive or
# JSON mode. Build failures were not clearly communicated. The JAR existence
# check was missing, which could lead to silent launch failures.
# This function must strictly respect output helpers and use quoted paths.
#
# CRITICAL NOTES:
# - Uses `exec` so Ctrl+C works naturally and process replacement is clean
# - Relies on util_src_user_shell_conf() having loaded SDKMAN Java/Maven
# - Default login (admin / admin123) is shown for user convenience
#
# CIAO PRINCIPLES APPLIED: 1 (Caution), 2 (Intentional), 3 (Anti-fragile),
# 4 (Over-protect - never simplify output path), 14 (Non-interactive safety)
#
# !!! ALL OUTPUT MUST GO THROUGH out_info/out_success/out_warn/out_die/out_empty_line !!!
# !!! DO NOT ADD RAW echo OR printf !!!
#
# Last reviewed: 29 April 2026
# =============================================================================

ruo_build_run() {
    # --- Safe Variable Defaults ---
    : "${PROJECT_DIR:=${HOME}/${PROJECT_NAME}}"
    : "${PORT:=8080}"
    : "${JSON:=0}"
    : "${QUIET:=0}"

    out_info "Building RuoYi project (this may take a few minutes)..."

    cd "${PROJECT_DIR}" || out_die "Cannot cd into ${PROJECT_DIR}"

    mvn clean package -Dmaven.test.skip=true || {
        out_warn "Build failed. Try debugging with:"
        out_plain "  cd \"${PROJECT_DIR}\" && mvn clean package -Dmaven.test.skip=true"
        exit 1
    }

    # Check that the jar was actually produced
    local jar_file="${PROJECT_DIR}/ruoyi-admin/target/ruoyi-admin.jar"
    if [ ! -f "${jar_file}" ]; then
        out_die "Build succeeded but jar file not found: ${jar_file}"
    fi

    if [ "${JSON}" -eq 1 ]; then
        out_json "out_success" "Build completed" "jar" "${jar_file}" "port" "${PORT}"
        return 0
    fi

    out_success "Build completed successfully."
    out_empty_line
    msg "=============================================================="
    msg "  ${PROJECT_NAME} is starting..."
    msg "  → Open browser: http://localhost:${PORT}"
    msg "  → Default login: admin / admin123"
    msg "  → Press Ctrl+C to stop"
    msg "=============================================================="
    out_empty_line

    # Run the application (uses SDKMAN Java if sourced correctly)
    exec java -jar "${jar_file}"
}

