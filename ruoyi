# =============================================================================
# ruo_clone() - Clone and prepare the official RuoYi project
# =============================================================================
#
# GENERAL PURPOSE:
# Clones the official RuoYi repository ($RUOYI_GIT_REPO), updates Java version
# in pom.xml, adjusts the server port in application.yml, and prepares the project
# for Maven build. 
#
# This function is the first step after SDKMAN/Java/Maven setup and before
# database configuration (MySQL or MariaDB).
#
# ────────────────────────────────────────────────
# CIAO PRINCIPLES APPLIED (v2.9.1)
# ────────────────────────────────────────────────
# Principle 1  (Caution)               - Repeated safe defaults, explicit checks
# Principle 2  (Intentional Verbosity) - Full General Purpose + heavy comments
# Principle 3  (Anti-fragile)          - Survives existing project, partial git failures
# Principle 7  (Reusable Protection)   - DO NOT MODIFY warning
# Principle 10 (Right Backup Strategy) - Dated backup before rm -rf or sed modifications
# Principle 14 (Interactive vs Non-Interactive) - Respects FORCE_REINSTALL and non-TTY safely
# Principle 16 (Input Pattern Checking) - Validates PROJECT_DIR and FORCE flag
#
# CRITICAL DEFENSIVE RULES:
# 1. Never assume ${PROJECT_DIR} is empty or safe to delete.
# 2. Always create a dated backup (Principle 10) before any rm -rf or sed.
# 3. Respect --force / FORCE_REINSTALL — do not delete user data silently.
# 4. All user-visible messages MUST go through out_info()/out_success()/out_warn()/out_die() only.
# 5. Git clone uses --depth 1 for speed and minimal footprint.
# 6. sed operations are defensive (2>/dev/null || true) but still backed up first.
#
# NON-INTERACTIVE MODE (curl | sh):
#   - No prompt
#   - Always backup existing folder then replace (as requested)
#
# Last reviewed: 29 April 2026
# =============================================================================

ruo_clone() {
    # --- Safe Variable Defaults (repeated on purpose - CIAO Principle 1) ---

    : "${APP_NAME:=app}"
    : "${PROJECT_NAME:=${APP_NAME}-demo}"
    : "${PROJECT_DIR:=${HOME}/${PROJECT_NAME}}"
    : "${FORCE_REINSTALL:=0}"
    : "${RUOYI_GIT_REPO:=https://github.com/yangzongzhuan/RuoYi.git}"
    : "${JAVA_VERSION:=21}"
    : "${PORT:=8080}"
    : "${JSON:=0}"
    : "${QUIET:=0}"

    out_info "Cloning RuoYi project..."

    # Backup strategy before any destructive action (CIAO Principle 10)
    if [ -d "${PROJECT_DIR}" ]; then
        util_backup "${PROJECT_DIR}" "pre-clone" || out_warn "Backup failed — continuing with caution"
    fi

    if [ -d "${PROJECT_DIR}" ]; then
        # Detect non-interactive mode (curl | sh, no TTY, CI, etc.)
        if ! [ -t 0 ] || [ "${QUIET}" = "1" ] || [ "${FORCE_REINSTALL}" = "1" ]; then
            # Non-interactive: backup + replace (as requested)
            out_info "Non-interactive mode detected (or --force used) → replacing existing folder"
            if [ -z "${PROJECT_DIR}" ] || [ "${PROJECT_DIR}" = "/" ] || [ "${PROJECT_DIR}" = "${HOME}" ]; then
                out_die "Refusing to rm -rf dangerous path: ${PROJECT_DIR}"
            fi
            rm -rf "${PROJECT_DIR}" || out_die "Failed to remove old project directory"
        else
            # Interactive mode: ask user
            out_warn "Project folder already exists: ${PROJECT_DIR}"
            if prompt_yes_no "Do you want to REMOVE it and re-download (replace)?"; then
                out_info "User chose to replace → removing old project folder..."
                if [ -z "${PROJECT_DIR}" ] || [ "${PROJECT_DIR}" = "/" ] || [ "${PROJECT_DIR}" = "${HOME}" ]; then
                    out_die "Refusing to rm -rf dangerous path: ${PROJECT_DIR}"
                fi
                rm -rf "${PROJECT_DIR}" || out_die "Failed to remove old project directory"
            else
                out_info "Skipping download - using existing project"
                out_info "Use --force to reset (data will be backed up first)."
                return 0
            fi
        fi
    fi

    # Perform clone
    git clone --depth 1 "${RUOYI_GIT_REPO}" "${PROJECT_DIR}" || out_die "Git clone failed"

    cd "${PROJECT_DIR}" || out_die "Cannot cd into ${PROJECT_DIR}"

    # Backup again before any file modifications (sed)
    util_backup "${PROJECT_DIR}/pom.xml" "pre-sed" || true
    util_backup "${PROJECT_DIR}/ruoyi-admin/src/main/resources/application.yml" "pre-sed" || true

    # Update Java version (defensive sed)
    sed -i "s|<java.version>.*</java.version>|<java.version>${JAVA_VERSION}</java.version>|g" pom.xml 2>/dev/null || true

    # Update port (defensive)
    local config_file="ruoyi-admin/src/main/resources/application.yml"
    if [ -f "$config_file" ]; then
        sed -i "s/port: 80/port: ${PORT}/g" "$config_file" 2>/dev/null || true
        out_info "Updated server port to ${PORT} in ${config_file}"
    else
        out_warn "application.yml not found — port update skipped"
    fi

    out_success "RuoYi project ready at ${PROJECT_DIR}"
    out_success "Use '${APP_NAME} mysql' or '${APP_NAME} mariadb' (default) for database setup next."
}

# =============================================================================
# debconf_noninteractive_db() - Helper for non-interactive package setup
# =============================================================================
#
# GENERAL PURPOSE:
# Pre-configures debconf answers for MySQL/MariaDB installation in non-interactive mode.
#
# ────────────────────────────────────────────────
# CIAO PRINCIPLES APPLIED
# ────────────────────────────────────────────────
# Principle 1, 3, 7, 9, 14
#
# CRITICAL: Used only when no TTY is detected.
#
# !!! DO NOT MODIFY OR SIMPLIFY THIS FUNCTION !!!
# Designed to be reusable in other projects.
#
# Last reviewed: 29 April 2026
# =============================================================================

debconf_noninteractive_db() {
    local engine="$1"   # mysql or mariadb
    local root_pass="$2"

    if [ -z "$root_pass" ]; then
        root_pass=$(util_generate_db_pass)
        out_info "Generated random root password: ${root_pass}"
        out_info "Save this password! It will NOT be shown again."
    fi

    echo "mariadb-server-${engine}/root_password password ${root_pass}" | sudo debconf-set-selections 2>/dev/null || true
    echo "mariadb-server-${engine}/root_password_again password ${root_pass}" | sudo debconf-set-selections 2>/dev/null || true
    echo "${engine}-server/root_password password ${root_pass}" | sudo debconf-set-selections 2>/dev/null || true
    echo "${engine}-server/root_password_again password ${root_pass}" | sudo debconf-set-selections 2>/dev/null || true

