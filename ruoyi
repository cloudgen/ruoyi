# =============================================================================
# db_setup_mariadb() - Install, configure and verify MariaDB for RuoYi
# =============================================================================
#
# GENERAL PURPOSE:
# Installs MariaDB server (via internal sudo), creates database and user,
# imports RuoYi schema, updates application-druid.yml, and performs verification.
#
# ────────────────────────────────────────────────
# STEPS (in order - preserved from original 2.0.0 pattern)
# ────────────────────────────────────────────────
# 1. Backup application-druid.yml before any modification
# 2. Verify PROJECT_DIR exists (fail early if missing)
# 3. cd into project
# 4. Internal sudo escalation for apt install mysql-server
# 5. Start & enable mysql service
# 6. Generate or use DB_PASSWORD for root/user
# 7. Create database, user, grant privileges, flush
# 8. Import main schema (ry*.sql) and quartz.sql if present
# 9. Update application-druid.yml with correct DB name/user/password
#
# ────────────────────────────────────────────────
# CRITICAL DEFENSIVE RULE - INTERNAL SUDO ESCALATION PATTERN
# ────────────────────────────────────────────────
#
# SACRED BEHAVIOR (DO NOT VIOLATE - CIAO PRINCIPLE 1 & 3):
# The command `ruoyi mariadb` MUST work when executed as a normal user
# (without typing "sudo ruoyi mariadb" manually).
#
# The script is allowed to internally escalate using `sudo` ONLY for specific
# privileged operations:
#   • apt-get update && apt-get install mariadb-server
#   • systemctl start/enable
#   • mysql client commands (database creation, user grant, schema import)
#
# It MUST NOT require the user to run the command with external sudo.
# This pattern was working in the original script and is sacred.
#
# Violating this (e.g. adding "if not root then out_die" check) is a regression
# and breaks user experience + PROJECT_DIR detection.
#
# This rule exists because:
# - It provides a clean, simple user command (`ruoyi mariadb`)
# - It keeps PROJECT_DIR under the original user's home
# - It follows Least Privilege (Principle 8) by escalating only when necessary
#
# Any future AI assistant, code reviewer, or refactoring MUST respect this rule.
# If you are tempted to "make it require sudo for simplicity", STOP.
# That path has already introduced bugs repeatedly.
#
# CIAO Reminder: This is exactly why we need strict defensive coding —
# to prevent well-intentioned changes from breaking established behavior.
#
# ────────────────────────────────────────────────
# YOUR ORIGINAL REQUIREMENT (recorded here for safety - DO NOT VIOLATE):
# "The setup database should try to check what is the current db_user and 
# db_password stored in application-druid.yml BEFORE backup.
# Within the same procedures, it should check if the db_user exists, 
# if the db_password correct.
# If they are correct, no need to create a new db_user and corresponding db_password."
#
# Decision Logic:
# - Read config BEFORE any backup
# - If user exists AND password correct → reuse (no backup, no create, no yml change)
# - If user exists but password wrong → strong warning, do NOT create/change
# - If user does not exist → create new + backup + update yml
#
# This protects against accidental password change on repeated runs.
#
# CIAO PRINCIPLES APPLIED:
# Principle 1 (Caution), 2 (Verbosity), 3 (Anti-fragile), 7 (Reusable Protection),
# 8 (Least Privilege), 10 (Backup Strategy), 14 (Interactive vs Non-Interactive)
#
# !!! DO NOT MODIFY OR SIMPLIFY THE SUDO ESCALATION LOGIC !!!
# Designed to be reusable while preserving original user workflow.
#
# Last reviewed: 29 April 2026
# =============================================================================

db_setup_mariadb() {
    # --- Safe Variable Defaults ---
    : "${APP_NAME:=app}"
    : "${PROJECT_NAME:=${APP_NAME}-demo}"
    : "${PROJECT_DIR:=${HOME}/${PROJECT_NAME}}"
    : "${DB_NAME:=${APP_NAME}_db}"
    : "${DB_USER:=${APP_NAME}_user}"
    : "${JSON:=0}"
    : "${QUIET:=0}"

    out_info "Setting up MariaDB (default database engine for RuoYi)"

    if [ ! -d "${PROJECT_DIR}" ]; then
        out_die "Project directory ${PROJECT_DIR} not found. Run 'ruoyi' first as normal user."
    fi

    cd "${PROJECT_DIR}" || out_die "Cannot cd into ${PROJECT_DIR}"

    out_info "Installing MariaDB server (requires sudo)..."
    sudo apt-get update -y && \
    sudo apt-get install -y mariadb-server mariadb-client || out_die "MariaDB installation failed"

    sudo systemctl start mariadb 2>/dev/null || out_warn "Failed to start mariadb service"
    sudo systemctl enable mariadb 2>/dev/null || out_warn "Failed to enable mariadb on boot"

    local config_file="ruoyi-admin/src/main/resources/application-druid.yml"
    local full_config_path="${PROJECT_DIR}/${config_file}"

    # === CLEAN & SAFE DECISION BLOCK ===
    local lines
    lines=$(db_check_credentials "$full_config_path" 2>/dev/null)
    local use_existing=$(echo "$lines" | sed -n '1p')
    local final_db_name=$(echo "$lines" | sed -n '2p')
    local final_db_user=$(echo "$lines" | sed -n '3p')
    local final_db_pass=$(echo "$lines" | sed -n '4p')

    # Respect config dbname if present, else fallback
    if [ "${final_db_user}" = "root" ]; then
        if db_prompt_for_new_user; then
            # User wants new dedicated user
            final_db_user="${DB_USER}"
            final_db_pass="$(util_generate_db_pass)"
            use_existing=0
            out_warn "🔄 Will create new user '${final_db_user}' with fresh password" >&2
        else
            use_existing=1
            out_warn "⚠️  Keeping root user as requested" >&2
        fi
    else
        out_info "non-root db-user: ${final_db_user}" >&2
    fi

    if [ "$use_existing" = "1" ]; then
        out_info "Re-using existing valid credentials from application-druid.yml" >&2
    else
        final_db_pass=$(db_create_new_user "$final_db_user" "${final_db_pass:-$(util_generate_db_pass)}" "$final_db_name")
    fi

    # GRANT only for new users
    if [ "$use_existing" != "1" ]; then
        sudo mysql -e "GRANT ALL PRIVILEGES ON \`${final_db_name}\`.* TO '${final_db_user}'@'localhost';" 2>/dev/null || true
        sudo mysql -e "FLUSH PRIVILEGES;" 2>/dev/null || true
    fi

    # === Schema import - use the SAME db name as config ===
    local sql_file=$(ls sql/ry*.sql 2>/dev/null | sort -r | head -n 1)
    if [ -n "$sql_file" ]; then
        sudo mysql "${final_db_name}" < "$sql_file" && \
            out_info "Main schema imported into ${final_db_name}" || \
            out_warn "Schema import failed"
    fi
    if [ -f "sql/quartz.sql" ]; then
        sudo mysql "${final_db_name}" < sql/quartz.sql && \
            out_info "Quartz tables imported into ${final_db_name}" || \
            out_warn "Quartz import failed"
    fi

    # Final test
    out_info "Performing final connection test..."
    if db_test_credentials "$final_db_user" "$final_db_pass" "$final_db_name"; then
        out_success "✅ Final database connection test passed"
    else
