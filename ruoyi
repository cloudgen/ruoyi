# =============================================================================
# main_ruoyi_app() - Main dispatcher and entry point
# =============================================================================
#
# IMPORTANT:
# This is the single entry point of the entire script.
# All business logic lives in dedicated functions.
#
# Design Principles:
# - Auto-install for `curl | bash` must stay at the top
# - Flag-first parsing for clean option handling
# - Early sourcing of user shell config (critical for SDKMAN)
# - Clear command dispatch table
#
# Safe Variable Defaults (repeated intentionally)
#
# CRITICAL WARNINGS:
# - Do NOT move the auto-install block
# - Do NOT remove `source_user_shell_config()` — it fixes most "command not found" issues
# - PROJECT_DIR default is intentionally generic (`${HOME}/app`) as requested
# - Respect root vs non-root isolation everywhere
#
# !!! DO NOT REMOVE OR SIMPLIFY THE AUTO-INSTALL BLOCK !!!
# It serves as a strong reminder for future maintenance and AI assistants.
#
# Last reviewed & aligned with CIAO defensive programming principles: 14 April 2026
# =============================================================================

main_ruoyi_app() {
    # Safe defaults (repeated on purpose - defensive style)
    : "${HOME:=/root}"
    : "${GLOBAL_BIN:=/usr/local/bin}"
    : "${USER_BIN:=${HOME}/.local/bin}"
    : "${PROJECT_DIR:=${HOME}/app}"
    : "${NO_RUN:=0}"
    : "${RESET_PROJECT:=0}"

    # <<< IMPORTANT: Source user shell configuration >>>
    # This must happen early so that PATH, SDKMAN, and user environment
    # are available for ALL sub-commands (about, run, version-check, etc.)
    source_user_shell_config

    local cmd="setup"

    # === AUTO-INSTALL FOR ONE-LINER (curl | bash) ===
    # This MUST stay at the top before any argument parsing
    if ! is_installed && [ $# -eq 0 ]; then
        if [ "${JSON}" -eq 1 ] || [ "${QUIET}" -eq 1 ]; then
            perform_self_install_v2
        else
            maybe_install_v3
        fi
    fi

    # === FLAG-FIRST ARGUMENT PARSING (consistent with pomo style) ===
    while [ $# -gt 0 ]; do
        case "$1" in
            --project-dir)
                if [ -z "$2" ]; then
                    die "--project-dir requires a path"
                fi
                PROJECT_DIR="$2"
                shift
                ;;
            --no-run)
                NO_RUN=1
                ;;
            --quiet|-q)     QUIET=1 ;;
            --json)         JSON=1; QUIET=1 ;;
            --force)        FORCE=1 ;;
            --force-user)   FORCE_USER=1 ;;
            --force-root)   FORCE_ROOT=1 ;;
            --mysql)        FORCE_MYSQL=1 ;;
            --mariadb)      FORCE_MARIADB=1 ;;
            --help|-h)      cmd="help";;
            --*)            ;;
            -*)             ;;
            *)              cmd="$1" ;;
        esac
        shift
    done

    # === Command Dispatch ===
    case "${cmd}" in
        version)
            if [ "${JSON}" -eq 1 ]; then
                output_json "version" "" "app" "${APP_NAME}" "version" "${VERSION}"
            else
                msg "${APP_NAME} version ${VERSION}"
            fi
            exit 0
            ;;

        version-check)
            version_check_v2
            exit 0
            ;;

        self-update)
            self_update_v3
            exit 0
            ;;

        self-uninstall)
            self_uninstall_v2
            exit 0 ;;

        about)
            show_about_ruoyi_app
            exit 0
            ;;

        help)
            show_ruoyi_help
            exit 0
            ;;

        setup)  
            setup_sdkman;
            setup_java;
            setup_maven;
            clone_ruoyi ;
            exit 0 ;;

        mysql|mariadb|db)
            setup_database;
            exit 0 ;;

        redis)
            setup_redis_for_ruoyi;
            exit 0 ;;

        run)
            build_run
            exit 0 ;;
        *)
            die "Invalid command: ${cmd}"
            ;;
    esac

    if [ "${NO_RUN}" -eq 1 ]; then
        if [ "${JSON}" -eq 1 ]; then
            output_json "success" "" \
                "message" "Environment and project setup completed" \
                "project_dir" "${PROJECT_DIR}" \
                "no_run" "true"
        else
            success "Environment and project setup completed (--no-run)."
            success "Project location: ${PROJECT_DIR}"
        fi
        exit 0
    fi
}

# Call the main function
main_ruoyi_app "$@"