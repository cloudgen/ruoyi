            --project|--project-dir)
                if [ -z "$2" ]; then
                    out_die "--project requires a path"
                fi
                PROJECT_DIR="$2"
                shift
                ;;
            --no-run)
                NO_RUN=1
                ;;
            --quiet|-q)
                QUIET=1
                ;;
            --json)
                JSON=1
                QUIET=1
                ;;
            --force)
                FORCE_REINSTALL=1
                ;;
            --force-user)
                FORCE_USER=1
                ;;
            --force-global)
                FORCE_GLOBAL=1
                ;;
            --mysql)
                FORCE_MYSQL=1
                ;;
            --mariadb)
                FORCE_MARIADB=1
                ;;
            --help|-h)
                cmd="help"
                ;;
            --*)
                out_warn "Unknown option: $1"
                ;;
            *)
                cmd="$1"
                ;;
        esac
        shift
    done

    # === MAKE PROJECT_DIR ABSOLUTE (Critical Fix) ===
    if [ -n "${PROJECT_DIR}" ]; then
        PROJECT_DIR="$(realpath -m "${PROJECT_DIR}" 2>/dev/null || echo "${PROJECT_DIR}")"
    fi

    out_info "Using project directory: ${PROJECT_DIR}" >&2   # debug

    # === Command Dispatch ===
    case "${cmd}" in
        version)
            if [ "${JSON}" -eq 1 ]; then
                out_json "version" "" "app" "${APP_NAME}" "version" "${VERSION}"
            else
                msg "${APP_NAME} version ${VERSION}"
            fi
            exit 0
            ;;

        version-check)
            ver_check
            exit 0
            ;;

        self-update)
            inst_self_update
            exit 0
            ;;

        self-uninstall)
            inst_self_uninstall
            exit 0 ;;

        about)
            ruo_about
            exit 0
            ;;

        help)
            ruo_help
            exit 0
            ;;

        setup|"" )   # default when no command or only flags
            setup_sdkman
            setup_java_21
            setup_maven_3_9
            ruo_clone
            exit 0 ;;

        mysql|mariadb|db)
            db_setup
            exit 0 ;;

        db-extract)
            shift
            db_extract_credentials "$@"
            exit 0
            ;;

        redis)
            setup_redis_for_ruoyi
            exit 0 ;;

        run)
            ruo_build_run
            exit 0 ;;

        *)
            out_die "Invalid command: ${cmd}"
            ;;
    esac

    if [ "${NO_RUN}" -eq 1 ]; then
        out_success "Environment and project setup completed (--no-run)."
        out_success "Project location: ${PROJECT_DIR}"
        exit 0
    fi
}

# Final call - main-entry at the bottom as requested
main_ruoyi_app "$@"
