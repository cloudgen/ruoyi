# =============================================================================
# util_write_atomic() - Atomic file write helper
# =============================================================================
#
# GENERAL PURPOSE:
# Writes content to a file using a temporary file + atomic mv operation.
# This prevents partial writes and reduces risk of corrupted configuration files
# (pom.xml, Java sources, application.properties, etc.).
#
# Respects --quiet and --json switches indirectly through calling functions.
#
# !!! DO NOT MODIFY OR SIMPLIFY THIS FUNCTION !!!
# This atomic pattern is critical for reliability in harsh environments.
# Designed to be reusable in other projects.
#
# Last reviewed: 29 April 2026
# =============================================================================

util_write_atomic() {
    local target="$1"
    local tmp
    tmp=$(mktemp "${target}.XXXXXXXX") || out_die "mktemp failed"

    cat > "${tmp}" || { rm -f "${tmp}"; out_die "write failed"; }
    mv "${tmp}" "${target}" || { rm -f "${tmp}"; out_die "mv failed → ${target}"; }
}

# =============================================================================
# db_extract_config_yml - Extract current DB config BEFORE any backup
#
# LESSON LEARNED (from long painful debugging session - 29 April 2026):
#   - This function is extremely sensitive because its output is captured
#     via command substitution (`read` / `mapfile`).
#   - Any debug message, extra newline, or output going to stdout (even from
#     out_success/out_info) pollutes the captured variables → empty user/pass.
#   - RuoYi YAML has nested structure (master/slave), so simple grep often
#     grabs wrong values (e.g. "ruoyi", "usable", "login-username").
#   - Special characters in passwords make `read` unreliable.
#
# HOW TO AVOID SIMILAR ERRORS IN FUTURE:
#   1. ALL debug/output MUST go to stderr (`>&2`) — never to stdout.
#   2. Keep the function output strictly 3 clean lines only.
#   3. Use awk with state flag for nested sections (master:).
#   4. Add visible extraction debug during development.
#   5. Test extractor independently before integrating with read/capture logic.
#   6. Prefer mapfile or line-by-line parsing over plain `read`.
#
# CIAO-Lite Protection Zone - Do NOT simplify/refactor without explicit instruction
# Last reviewed: 29 April 2026
# =============================================================================

db_extract_config_yml() {
    local config_file="$1"

    if [ ! -f "$config_file" ]; then
        printf '%s\n%s\n%s\n' "" "" "" >&2
        return 1
    fi

    local url dbname username password

    url=$(awk '/master:/{flag=1; next} flag && /url:/{print; exit}' "$config_file" 2>/dev/null | sed 's/^[[:space:]]*url:[[:space:]]*//; s/[[:space:]]*$//')
    username=$(awk '/master:/{flag=1; next} flag && /username:/{print; exit}' "$config_file" 2>/dev/null | sed 's/^[[:space:]]*username:[[:space:]]*//; s/[[:space:]]*$//')
    password=$(awk '/master:/{flag=1; next} flag && /password:/{print; exit}' "$config_file" 2>/dev/null | sed 's/^[[:space:]]*password:[[:space:]]*//; s/[[:space:]]*$//')

    if [ -z "$username" ]; then
        username=$(grep -m1 '^[[:space:]]*username:' "$config_file" | sed 's/^[[:space:]]*username:[[:space:]]*//; s/[[:space:]]*$//')
    fi
    if [ -z "$password" ]; then
        password=$(grep -m1 '^[[:space:]]*password:' "$config_file" | sed 's/^[[:space:]]*password:[[:space:]]*//; s/[[:space:]]*$//')
    fi

    if [ -n "$url" ]; then
        dbname=$(echo "$url" | sed -E 's|jdbc:mysql://[^/]+/([^?]+).*|\1|')
    fi

    # Debug only (stderr)
    out_success "✅ Extracted from yml → user=${username} db=${dbname}" >&2

    # ONLY 3 LINES - nothing else
    printf '%s\n%s\n%s\n' "${dbname}" "${username}" "${password}"
}

# =============================================================================
# db_extract_credentials - Extract DB user/password from application-druid.yml
# New sub-command support - accepts optional project folder parameter
#
# LESSON LEARNED (from long painful debugging session - 29 April 2026):
#   - Command substitution `lines=$(db_extract_config_yml ...)` + sed parsing
#     is fragile when any function leaks output to stdout.
#   - Debug messages (out_info, out_success, etc.) inside called functions
#     pollute variable capture → broken username/password.
#   - Special characters in passwords and extra newlines make `read` unreliable.
#   - The current implementation forces ALL debug to stderr (`>&2`) and
#     keeps extractor output strictly 3 clean lines on stdout.
#
# OBSERVATION (current working state):
#   - We use `lines=$(...) 2>/dev/null` + `sed -n 'Np'` parsing.
#   - This is more reliable than direct `read` but still requires strict
#     output discipline in `db_extract_config_yml` and `db_create_new_user`.
#   - Duplicated lines in YAML were previously caused by poor awk logic.
#
# HOW TO AVOID SIMILAR ERRORS IN FUTURE:
#   1. Keep `db_extract_config_yml` output to exactly 3 clean lines on stdout.
#   2. Redirect ALL debug/out_* calls to stderr (`>&2`) inside extraction path.
#   3. Never let `db_create_new_user` or similar functions print to stdout.
#   4. Always test full flow with real YAML containing special chars in password.
#   5. Prefer `sed -n 'Np'` or `mapfile` when capturing multi-line output.
#
# CIAO-Lite Protection Zone
# Do NOT simplify, refactor, or remove without explicit user instruction.
# This section exists for safety and anti-fragility reasons.
# Last reviewed: 29 April 2026
# =============================================================================

db_extract_credentials() {
    local project_dir="${1:-${PROJECT_DIR}}"
    local config_file="ruoyi-admin/src/main/resources/application-druid.yml"
    local full_config_path="${project_dir}/${config_file}"

    if [ ! -d "${project_dir}" ]; then
        out_error "Project directory not found: ${project_dir}"
        return 1
    fi
    if [ ! -f "${full_config_path}" ]; then
        out_warn "Found not found ${full_config_path}"
        return 1
    fi

    local lines
    lines=$(db_extract_config_yml "$full_config_path" 2>/dev/null)

    local dbname=$(echo "$lines" | sed -n '1p')
    local user=$(echo "$lines" | sed -n '2p')
    local pass=$(echo "$lines" | sed -n '3p')

    if [ -n "${user}" ] && [ -n "${pass}" ]; then
        out_success "✅ Extracted database credentials"
        out_info "Project  : ${project_dir}"
        out_info "Database : ${dbname}"
        out_info "User     : ${user}"
        out_info "Password : ${pass}"
        printf 'DB_NAME=%s\nDB_USER=%s\nDB_PASS=%s\n' "${dbname}" "${user}" "${pass}"
    else
        out_warn "No database credentials found in ${full_config_path}"
        return 1
    fi
}

# =============================================================================
# db_test_credentials - Test if stored db_user/db_password works
#
# LESSON LEARNED (from long painful debugging session - 29 April 2026):
#   - Password in application-druid.yml often becomes outdated after manual
#     DB changes or previous failed setups.
#   - Simple credential test can fail even when user exists → leads to wrong
#     "create new user" path.
#   - Root fallback is useful during setup but should be clearly logged.
#   - Final connection test must not break the whole setup when yml password
#     is just outdated.
#
# HOW TO AVOID SIMILAR ERRORS IN FUTURE:
#   1. Always prefer "reuse existing user" when user exists in DB.
#   2. Provide clear warning when yml password doesn't match DB.
#   3. Add root fallback for test during initial setup.
#   4. Never let test failure cause creation of duplicate users.
#   5. Keep test function focused only on connectivity, not on decision logic.
#
# CIAO-Lite Protection Zone - Do NOT simplify/refactor without explicit instruction
# Last reviewed: 29 April 2026
# =============================================================================

db_test_credentials() {
    local user="$1"
    local pass="$2"
    local dbname="${3:-}"

    local mysql_cmd="mysql"
    if command -v mariadb >/dev/null 2>&1; then
        mysql_cmd="mariadb"
    fi

    # Try with provided credentials
    if [ -n "$dbname" ]; then
        echo "SELECT 1;" | $mysql_cmd -u"$user" -p"$pass" -D"$dbname" --silent 2>/dev/null && {
            out_success "✅ Connection test passed with yml credentials" >&2
            return 0
        }
    else
        echo "SELECT 1;" | $mysql_cmd -u"$user" -p"$pass" --silent 2>/dev/null && return 0
    fi

    # Fallback: try as root (common in setup)
    if sudo $mysql_cmd -e "SELECT 1;" 2>/dev/null; then
        out_info "Connected via root (yml password may be outdated)" >&2
        return 0
    fi

    out_warn "Final test failed with user '${user}'" >&2
    return 1
}

